{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.stdout.write(require('fs').readFileSync(process.env.CLAUDE_PLUGIN_ROOT + '/hooks/reminder.txt','utf8'))\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/hooks/pc-gate.js\""
          }
        ]
      }
    ]
  }
}
